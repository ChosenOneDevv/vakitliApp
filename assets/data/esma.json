  {"id":3,"arabic":"اَلْمَلِكُ","transliteration":"El-Melik","meaning":"Bütün kâinatın gerçek sahibi ve mutlak hükümdarı."},
  {"id":4,"arabic":"اَلْقُدُّوسُ","transliteration":"El-Kuddûs","meaning":"Her türlü eksiklikten münezzeh, pâk ve temiz olan."},
  {"id":5,"arabic":"اَلسَّلَامُ","transliteration":"Es-Selâm","meaning":"Her türlü tehlikeden kullarını selâmete çıkaran, esenlik veren."},
